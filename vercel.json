{
  "buildCommand": "npm run build --workspace public",
  "outputDirectory": "public/dist",
  "rewrites": [
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/main.html", "destination": "/html/main.html" },
    { "source": "/login.html", "destination": "/html/login.html" },
    { "source": "/signup.html", "destination": "/html/signup.html" },
    { "source": "/privacy.html", "destination": "/html/privacy.html" },
    { "source": "/imprint.html", "destination": "/html/imprint.html" }
  ]
}

{
  "buildCommand": "npm run build --workspace public",
  "outputDirectory": "public/dist",
  "functions": {
    "api/src/server.ts": {
      "includeFiles": "api/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/src/server.ts" },
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/main", "destination": "/html/main.html" },
    { "source": "/login", "destination": "/html/login.html" },
    { "source": "/signup", "destination": "/html/signup.html" },
    { "source": "/privacy", "destination": "/html/privacy.html" },
    { "source": "/imprint", "destination": "/html/imprint.html" }
  ]
}
